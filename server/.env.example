# Copy this file to .env (in this same server/ folder) and fill in real values there.
# .env is where the actual secrets live — never paste real keys into chat, and
# never commit .env to source control.

# Required — your personal Anthropic account key. This is the primary path.
ANTHROPIC_API_KEY=

# Optional — Google Gemini Flash, used only as a fallback if the Anthropic
# call fails (timeout, 5xx, or rate limit). Leave blank for now; the server
# runs fine on Anthropic alone and simply skips the fallback until this is set.
GOOGLE_API_KEY=

# Port the local server listens on. Change only if 8787 is already in use.
PORT=8787

# Required for the real paywall — your Stripe secret key (sk_test_... while
# testing, sk_live_... once actually charging real cards). Never the
# publishable (pk_...) key here; that one's meant to be public, this one isn't.
STRIPE_SECRET_KEY=

# Optional — only needed once a webhook endpoint is registered against a
# real public URL in the Stripe Dashboard (or via `stripe listen` locally).
# The paywall works correctly without this; it's defense-in-depth for the
# case where a customer completes payment but closes the tab before the
# redirect back completes.
STRIPE_WEBHOOK_SECRET=

# Optional — gates POST /api/admin/access-codes (mint access codes remotely,
# without SSH/filesystem access to the host). Leave blank to leave that route
# fully inert (it 404s with no secret set, rather than being reachable with
# no auth at all). Set to a long random value if you want to use it.
ADMIN_SECRET=

# Required in production — sends magic-link sign-in emails via Resend
# (https://resend.com). Leave blank in local dev and the sign-in link is
# returned directly in the API response instead (see server/routes/auth.js).
# Once this is set, or once NODE_ENV=production, the link is emailed only —
# it never appears in a response body again.
RESEND_API_KEY=
# The "from" address Resend sends as. Must be a domain verified in your
# Resend account; falls back to Resend's shared onboarding@resend.dev sender
# if left blank (fine for testing, not for real deliverability).
EMAIL_FROM=

# Optional — where server/backup.js uploads its timestamped SQLite backup
# (a PUT-able URL: an S3 pre-signed URL, an R2/B2 bucket endpoint, etc).
# Leave blank and the backup is just written to local disk, path logged.
BACKUP_UPLOAD_URL=
# Optional — an Authorization header value to send with the upload, if the
# destination needs one (a pre-signed URL usually doesn't).
BACKUP_UPLOAD_AUTH=
