# Copy this file to .env (in this same server/ folder) and fill in real values there.
# .env is where the actual secrets live — never paste real keys into chat, and
# never commit .env to source control.

# Required — your personal Anthropic account key. This is the primary path.
ANTHROPIC_API_KEY=

# Optional — Google Gemini Flash, used only as a fallback if the Anthropic
# call fails (timeout, 5xx, or rate limit). Leave blank for now; the server
# runs fine on Anthropic alone and simply skips the fallback until this is set.
GOOGLE_API_KEY=

# Port the local server listens on. Change only if 8787 is already in use.
PORT=8787

# Required for the real paywall — your Stripe secret key (sk_test_... while
# testing, sk_live_... once actually charging real cards). Never the
# publishable (pk_...) key here; that one's meant to be public, this one isn't.
STRIPE_SECRET_KEY=

# Optional — only needed once a webhook endpoint is registered against a
# real public URL in the Stripe Dashboard (or via `stripe listen` locally).
# The paywall works correctly without this; it's defense-in-depth for the
# case where a customer completes payment but closes the tab before the
# redirect back completes.
STRIPE_WEBHOOK_SECRET=
